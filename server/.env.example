# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (see README section "MongoDB Atlas setup")
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/wecarechess?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS - the deployed/local frontend origin(s), comma-separated
CLIENT_ORIGIN=http://localhost:5173

# First admin account, created by `npm run seed`
ADMIN_NAME=Academy Admin
[email protected]
ADMIN_PASSWORD=ChangeThisPassword123!
